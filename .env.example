# OpenAIP API key (free account at openaip.net) — server-side only. Used by the vector-tile
# proxy /api/openaip/{z}/{x}/{y} to render global airspace polygons on the globe. Never exposed to the browser.
OPENAIP_API_KEY=

# Neon Postgres connection string (server-side only — never exposed to the browser).
# Used by the observation store: npm run db:migrate, npm run record, and the Vercel Cron/API.
# Provision with the Neon CLI (`neonctl projects create`) or the Vercel Marketplace.
DATABASE_URL=

# Shared secret for the observation-ingest cron endpoint (server-side only). The GitHub Actions
# scheduler sends it as a Bearer token to /api/cron/record; api/cron/record.mjs verifies it.
CRON_SECRET=

# Optional OpenSky server-side OAuth2 credentials.
# Anonymous OpenSky access is heavily rate-limited; authenticated access improves quota.
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# OpenSky fetch controls. Defaults are rate-limit safe for anonymous use.
OPENSKY_FETCH_ENABLED=true
OPENSKY_MIN_FETCH_INTERVAL_MS=
OPENSKY_MAX_TRACKS_PER_REGION=50
GDELT_BACKOFF_MS=1800000

# Optional Copernicus Data Space STAC scene metadata.
# Uses the public STAC endpoint for AOI/time-window scene existence, cloud cover, and platform metadata.
COPERNICUS_STAC_FETCH_ENABLED=true
COPERNICUS_STAC_COLLECTIONS=sentinel-2-l2a,sentinel-1-grd
COPERNICUS_STAC_LOOKBACK_HOURS=72
COPERNICUS_STAC_MIN_FETCH_INTERVAL_MS=21600000
COPERNICUS_STAC_MAX_SCENES_PER_REGION=6

# Optional NASA FIRMS thermal anomaly lookup.
# Requires a free server-side MAP_KEY. Do not expose the key to browser code.
NASA_FIRMS_MAP_KEY=
NASA_FIRMS_FETCH_ENABLED=true
NASA_FIRMS_SOURCE=VIIRS_SNPP_NRT
NASA_FIRMS_DAY_RANGE=1
NASA_FIRMS_CACHE_TTL_MS=3600000
NASA_FIRMS_MAX_RECORDS_PER_REGION=25

# Optional AISStream server-side WebSocket key.
# The browser must not connect to AISStream directly because the API key would be exposed.
AISSTREAM_API_KEY=
AISSTREAM_FETCH_ENABLED=true
AISSTREAM_FETCH_MS=20000
AISSTREAM_MAX_SHIPS_PER_REGION=30
AISSTREAM_CACHE_TTL_MS=1800000

# Optional ICAO API Data Service key.
# ICAO_API_KEY alone is not enough in this prototype; configure the exact NOTAM endpoint from the ICAO portal.
# Endpoint templates may use {location}, {icao}, {regionId}, {minLat}, {minLon}, {maxLat}, {maxLon}, {apiKey}.
ICAO_API_KEY=
ICAO_API_BASE_URL=https://dataservices.icao.int/api
ICAO_FIR_FETCH_ENABLED=true
ICAO_FIR_MIN_FETCH_INTERVAL_MS=86400000
ICAO_NOTAM_ENDPOINT=
ICAO_API_KEY_AUTH=query
ICAO_API_KEY_PARAM=api_key
ICAO_API_KEY_HEADER=x-api-key
ICAO_NOTAM_MAX_LOCATIONS_PER_REGION=2
ICAO_NOTAM_MAX_PER_REGION=8

# Optional SkyLink API Data Service for NOTAM.
# Requires RapidAPI subscription key + host header.
SKYLINK_NOTAM_FETCH_ENABLED=true
SKYLINK_NOTAM_API_KEY=
SKYLINK_NOTAM_API_HOST=skylink-api.p.rapidapi.com
SKYLINK_NOTAM_MAX_LOCATIONS_PER_REGION=2
SKYLINK_NOTAM_MAX_PER_REGION=8
